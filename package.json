{
  "name": "scopetrace",
  "version": "0.3.0",
  "description": "Track resource ownership and detect leaks in Node.js processes",
  "type": "module",
  "bin": {
    "scopetrace": "./dist/cli.js",
    "sctrace": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./zero-setup": {
      "import": {
        "types": "./dist/zero-setup/index.d.ts",
        "default": "./dist/zero-setup/index.js"
      },
      "require": {
        "types": "./dist/zero-setup/index.d.cts",
        "default": "./dist/zero-setup/index.cjs"
      }
    },
    "./register": {
      "import": {
        "types": "./dist/register.d.ts",
        "default": "./dist/register.js"
      },
      "require": {
        "types": "./dist/register.d.cts",
        "default": "./dist/register.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "check": "npm run type-check && npm test && npm run build",
    "fixture:cli-zero-bad": "npm run build && node ./dist/cli.js examples/zero-setup/bad-app.mjs",
    "fixture:cli-zero-good": "npm run build && node ./dist/cli.js examples/zero-setup/good-app.mjs",
    "dev": "tsup --watch",
    "fixture:bad": "npm run build && node examples/mini-projects/bad.mjs",
    "fixture:good": "npm run build && node examples/mini-projects/good.mjs",
    "fixture:zero-bad": "npm run build && node --import ./dist/register.js examples/zero-setup/bad-app.mjs",
    "fixture:zero-good": "npm run build && node --import ./dist/register.js examples/zero-setup/good-app.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run check",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": [
    "./dist/register.js",
    "./dist/register.cjs",
    "./dist/cli.js",
    "./dist/cli.cjs"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kdinisv/scopetrace.git"
  },
  "homepage": "https://github.com/kdinisv/scopetrace#readme",
  "bugs": {
    "url": "https://github.com/kdinisv/scopetrace/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "node",
    "leak",
    "leak-detection",
    "timer",
    "server",
    "diagnostics",
    "scope",
    "async",
    "handle",
    "open-handles",
    "resource-tracking",
    "graceful-shutdown",
    "jest",
    "vitest",
    "memory-leak",
    "asynclocalstorage"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
